{
  "name": "bagsapp-copytrading-bot",
  "version": "1.0.0",
  "description": "Solana copytrading bot for Bagsapp that monitors target wallets and copies their transactions",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "copytrading",
    "bagsapp",
    "trading-bot",
    "web3"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.87.6",
    "@solana/spl-token": "^0.3.9",
    "bs58": "^5.0.0",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/bs58": "^5.0.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  }
}
